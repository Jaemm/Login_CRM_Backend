<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Centralized Form</title>
    <link
      href='https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css'
      rel='stylesheet'
    />
    <style>
      .container { height: 100vh; display: flex; flex-direction: column; justify-content: center;
      align-items: center; } .flex-container { width: 300px; border: 1px solid #ccc; padding: 20px;
      border-radius: 8px; box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1); } .form-group { width: 100%;
      margin-bottom: 1rem; } label { width: 100%; margin-bottom: 0.5rem; } .form-control { width:
      100%; margin-bottom: 1rem; } .btn { width: 100%; }
    </style>
  </head>
  <body>
    <div class='container'>
      <h2 class='text-center'>{{{recover_password_title}}}</h2>
      <div class='flex-container'>
        <form id='passwordForm'>
          <div class='form-group'>
            <label for='newPassword'>{{{new_password}}} <span class='text-danger'>*</span></label>
            <input
              type='password'
              class='form-control'
              placeholder='{{enter_new_password}}'
              id='newPassword'
              name='newPassword'
              required
            />
          </div>
          <div class='form-group'>
            <label for='confirmPassword'>{{{confirm_password}}}
              <span class='text-danger'>*</span></label>
            <input
              type='text'
              class='form-control'
              placeholder='{{confirm_new_password}}'
              id='confirmPassword'
              name='confirmPassword'
              required
            />
          </div>
          <button type='submit' class='btn btn-primary'>{{{confirm}}}</button>
        </form>
      </div>
    </div>
    <script src='https://code.jquery.com/jquery-3.5.1.slim.min.js'></script>
    <script src='https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js'></script>
    <script src='https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js'></script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
      document.getElementById('passwordForm').addEventListener('submit', function (event) {
      event.preventDefault(); const email = "{{{email}}}"; const recoverPasswordToken = "{{{recoverPasswordToken}}}";
      const url = "{{{link}}}"; const app_id = "{{{app_id}}}"; const formData = { password:
      document.getElementById('newPassword').value, confirmPassword:
      document.getElementById('confirmPassword').value, email: email, app_id: app_id,
      recoveryPasswordToken: recoverPasswordToken }; fetch(url, { method: 'POST', headers: {
      'Content-Type': 'application/json' }, body: JSON.stringify(formData) }) .then(response => { if
      (!response.ok) { throw new Error('Network response was not ok'); } return response.json(); })
      .then(() => { window.location.href =
      'https://example.com/v1/api/consultants/passord-changed'; }) .catch(() => { alert('An error
      occurred. Please try again.'); }); }); });
    </script>
  </body>
</html>
