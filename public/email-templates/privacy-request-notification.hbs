<html lang='en'>
  <head>
    <meta http-equiv='Content-Type' content='text/html; charset=UTF-8' />
    <title>GDPR Privacy Request</title>
  </head>
  <body style='font-family:Arial,Helvetica,sans-serif;background:#f7f7f7;margin:0;padding:24px;color:#111'>
    <table width='100%' cellpadding='0' cellspacing='0' style='max-width:720px;margin:0 auto;background:#fff;border:1px solid #e5e7eb;border-radius:8px'>
      <tr>
        <td style='padding:24px'>
          <h1 style='margin:0 0 16px;font-size:20px'>New GDPR privacy request</h1>
          <p style='margin:0 0 8px'><strong>Request ID:</strong> {{requestId}}</p>
          <p style='margin:0 0 8px'><strong>Type:</strong> {{requestType}}</p>
          <p style='margin:0 0 8px'><strong>Status:</strong> {{status}}</p>
          <p style='margin:0 0 8px'><strong>Customer ID:</strong> {{customerId}}</p>
          <p style='margin:0 0 8px'><strong>Customer:</strong> {{customerName}} ({{customerEmail}})</p>
          <p style='margin:0 0 8px'><strong>Reason:</strong> {{reason}}</p>
          <p style='margin:16px 0 0;color:#6b7280;font-size:12px'>Created at {{createdAt}}</p>
        </td>
      </tr>
    </table>
  </body>
</html>
